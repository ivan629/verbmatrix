# ─── VerbMatrix env vars ────────────────────────────────────────
# Copy this file to `.env.local` for local development.
# In production (Vercel), set these in Project Settings → Environment Variables.

# Local development: bypass the paywall so you can review all lessons
# without entering a key. DO NOT set this in production.
# VITE_DISABLE_PAYWALL=true

# Local development: force analytics ON even when running outside the
# production domain. Useful for debugging event firing.
# VITE_ANALYTICS_OVERRIDE=true

# ─── LemonSqueezy (required for monetization) ───────────────────
VITE_REMOTE_VALIDATION=true
VITE_LS_CHECKOUT_RO=https://YOURSTORE.lemonsqueezy.com/buy/UUID-FOR-ROMANIAN
VITE_LS_CHECKOUT_ALL=https://YOURSTORE.lemonsqueezy.com/buy/UUID-FOR-ALL-ACCESS
VITE_LS_PRODUCT_RO=
VITE_LS_PRODUCT_ALL=