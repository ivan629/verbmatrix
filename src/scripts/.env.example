# ─── ElevenLabs (pre-generated audio) ─────────────────────────────────────
# Get your API key from elevenlabs.io → Profile → API Key
ELEVEN_API_KEY=

# PRIMARY Romanian voice — used for vocabulary, sentences, examples, and
# dialogue speaker A. Pick a NATIVE Romanian voice from the Voice Library
# (filter Language = Romanian). DO NOT use English voices like Rachel
# (21m00Tcm4TlvDq8ikWAM) or Adam (pNInz6obpgDQGcFmaJgB) — those produce
# English-accented Romanian even with the multilingual model.
#
# Top picks for a learning app (clarity > drama):
#   ▸ Mihai — Warm, Chill Narrator     (Narration | mid-pitch | best clarity)
#   ▸ Cristi Romana — Deep and Engaging  (Educational | deep)
#   ▸ Jora Slobod — Calm, Deep        (Narration | deep | most popular)
#
# Grab a voice ID via: Voice Library → open voice → ⋯ → Copy voice ID
ELEVEN_VOICE_ID=

# SECONDARY Romanian voice — used for dialogue speaker B so learners hear
# two distinct speakers. Optional; if blank, every line uses the primary
# voice. Recommended: a Romanian female voice, e.g.
#   ▸ Eva — Friendly & calm female-RO  (description says "clear, natural")
ELEVEN_VOICE_ID_SECONDARY=

# Model — leave as eleven_multilingual_v2 for pre-generated audio.
# Never use flash/turbo for Romanian — they degrade diacritics noticeably.
ELEVEN_MODEL_ID=eleven_multilingual_v2

# ─── Azure (runtime fallback if no MP3 cached) ────────────────────────────
# Optional. If unset, the app falls back to browser SpeechSynthesis.
VITE_AZURE_SPEECH_KEY=
VITE_AZURE_SPEECH_REGION=
VITE_AZURE_VOICE=
